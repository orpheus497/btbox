#!/bin/sh
##Script function and purpose: Main entry point for the btbox utility. Handles CLI argument parsing and dispatching to the VMM runner.
#
# btbox - Bluetooth Device Sandbox for FreeBSD
# Supports audio (A2DP, HFP/HSP), microphones, and HID peripherals
# (keyboards, mice, game controllers) via a Linux guest VM.
#

set -e

# Resolve the directory where this script lives
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

# Load Common Library
# When installed, libraries are in /usr/local/lib/btbox/
# When running from source, they are in the same directory as this script (src/)
if [ -f "${SCRIPT_DIR}/common.sh" ]; then
    BTBOX_SRC_DIR="${SCRIPT_DIR}"
    . "${BTBOX_SRC_DIR}/common.sh"
elif [ -f "${SCRIPT_DIR}/../lib/btbox/common.sh" ]; then
    BTBOX_SRC_DIR="$(cd "${SCRIPT_DIR}/../lib/btbox" && pwd)"
    . "${BTBOX_SRC_DIR}/common.sh"
else
    echo "Error: Cannot find common.sh library" >&2
    exit 1
fi

##Action purpose: Load configuration using common logic.
load_config

##Function purpose: Display usage information.
usage() {
    show_banner
    printf "Usage: btbox <command> [args]\n\n"
    printf "VM Management:\n"
    printf "  start                Start the btbox VM\n"
    printf "  stop                 Stop the btbox VM\n"
    printf "  status               Show VM status\n"
    printf "  console              Attach to VM console\n"
    printf "  check-hw             Verify hardware virtualization support\n\n"
    printf "Bluetooth Device Management:\n"
    printf "  scan                 Scan for nearby Bluetooth devices\n"
    printf "  devices              List paired/connected devices\n"
    printf "  info <MAC>           Show detailed device info (type, profiles)\n"
    printf "  pair <MAC>           Pair with a Bluetooth device\n"
    printf "  trust <MAC>          Trust a paired device\n"
    printf "  connect <MAC>        Connect to a paired device\n"
    printf "  disconnect <MAC>     Disconnect a device\n"
    printf "  remove <MAC>         Remove a paired device\n"
    exit 1
}

##Function purpose: Verify script is running as root.
check_root() {
    if [ "$(id -u)" -ne 0 ]; then
        ##Error purpose: Fail if not root.
        msg_err "btbox must be run as root."
        exit 1
    fi
}

##Function purpose: Check if the btbox VM is running.
check_vm_running() {
    if [ ! -e "/dev/vmm/$VM_NAME" ]; then
        msg_err "btbox VM is not running. Start it first with: btbox start"
        exit 1
    fi
}

##Function purpose: Validate a Bluetooth MAC address format.
validate_mac() {
    if ! echo "$1" | grep -qE '^[0-9A-Fa-f]{2}(:[0-9A-Fa-f]{2}){5}$'; then
        msg_err "Invalid MAC address: $1 (expected format: XX:XX:XX:XX:XX:XX)"
        exit 1
    fi
}

##Function purpose: Verify SSH key is configured for guest communication.
check_ssh_key() {
    _overlay="${BTBOX_ROOT}/guest/overlay/etc/btbox/host_authorized_keys"
    if [ -f "$_overlay" ]; then
        # Check if file has any non-comment, non-empty lines (actual keys)
        if ! grep -Eqv '^[[:space:]]*(#|$)' "$_overlay" 2>/dev/null; then
            msg_warn "No SSH public key found in $_overlay"
            msg_warn "Guest commands (scan/pair/connect) require SSH key access."
            msg_warn "Run: cat ~/.ssh/id_ed25519.pub >> $_overlay"
            msg_warn "Then rebuild: sh guest/build_alpine.sh"
        fi
    else
        msg_err "Missing SSH authorized keys file: $_overlay"
        msg_err "Guest commands (scan/pair/connect) require SSH key access."
        msg_err "Create the file and add your SSH public key, for example:"
        msg_err "  cat ~/.ssh/id_ed25519.pub >> $_overlay"
        msg_err "Then rebuild the guest image: sh guest/build_alpine.sh"
        exit 1
    fi
}

##Function purpose: Execute command(s) inside the guest VM over SSH.
guest_exec() {
    GUEST_SSH_IP="${GUEST_IP:-10.0.0.2}"
    BTBOX_KNOWN_HOSTS="/var/run/btbox_known_hosts"
    # Ensure the known_hosts file can be created
    mkdir -p "$(dirname "$BTBOX_KNOWN_HOSTS")" 2>/dev/null || true
    ssh -o BatchMode=yes \
        -o PreferredAuthentications=publickey \
        -o PasswordAuthentication=no \
        -o StrictHostKeyChecking=accept-new \
        -o UserKnownHostsFile="$BTBOX_KNOWN_HOSTS" \
        -o ConnectTimeout=5 \
        -o ServerAliveInterval=5 \
        -o ServerAliveCountMax=3 \
        "root@${GUEST_SSH_IP}" "$@"
    _rc=$?
    if [ "$_rc" -ne 0 ]; then
        msg_err "Guest command failed (exit code $_rc). Check VM status with: btbox status"
        return "$_rc"
    fi
}

##Action purpose: Parse command line arguments and execute sub-commands.
case "$1" in
    start)
        check_root
        check_ssh_key
        show_banner
        msg_info "Starting btbox..."
        # Call the VMM runner
        sh "${BTBOX_SRC_DIR}/vmm/bhyve_runner.sh" start
        ;;
    stop)
        check_root
        msg_info "Stopping btbox..."
        sh "${BTBOX_SRC_DIR}/vmm/bhyve_runner.sh" stop
        ;;
    status)
        ##Condition purpose: Check if VM device exists.
        if [ -e "/dev/vmm/$VM_NAME" ]; then
            msg_status "btbox is running."
        else
            msg_status "btbox is not running."
        fi
        ;;
    console)
        check_root
        ##Condition purpose: Check if console device exists.
        if [ -e "$NMDM_B" ]; then
            msg_info "Connecting to console... (Press ~ then . to exit)"
            cu -l "$NMDM_B"
        else
            ##Error purpose: Fail if console not found.
            msg_err "Console not available."
        fi
        ;;
    scan)
        check_root
        check_vm_running
        msg_info "Scanning for Bluetooth devices..."
        guest_exec "bluetoothctl --timeout 10 scan on; bluetoothctl devices"
        ;;
    pair)
        check_root
        check_vm_running
        if [ -z "$2" ]; then
            msg_err "Usage: btbox pair <MAC_ADDRESS>"
            exit 1
        fi
        validate_mac "$2"
        msg_info "Pairing with $2..."
        guest_exec "bluetoothctl pair $2"
        ;;
    connect)
        check_root
        check_vm_running
        if [ -z "$2" ]; then
            msg_err "Usage: btbox connect <MAC_ADDRESS>"
            exit 1
        fi
        validate_mac "$2"
        msg_info "Connecting to $2..."
        guest_exec "bluetoothctl connect $2"
        ;;
    disconnect)
        check_root
        check_vm_running
        if [ -z "$2" ]; then
            msg_err "Usage: btbox disconnect <MAC_ADDRESS>"
            exit 1
        fi
        validate_mac "$2"
        msg_info "Disconnecting $2..."
        guest_exec "bluetoothctl disconnect $2"
        ;;
    devices)
        check_root
        check_vm_running
        msg_info "Paired/Connected Bluetooth devices:"
        guest_exec "bluetoothctl devices"
        ;;
    info)
        check_root
        check_vm_running
        if [ -z "$2" ]; then
            msg_err "Usage: btbox info <MAC_ADDRESS>"
            exit 1
        fi
        validate_mac "$2"
        msg_info "Device info for $2..."
        guest_exec "bluetoothctl info $2"
        ;;
    trust)
        check_root
        check_vm_running
        if [ -z "$2" ]; then
            msg_err "Usage: btbox trust <MAC_ADDRESS>"
            exit 1
        fi
        validate_mac "$2"
        msg_info "Trusting $2..."
        guest_exec "bluetoothctl trust $2"
        ;;
    remove)
        check_root
        check_vm_running
        if [ -z "$2" ]; then
            msg_err "Usage: btbox remove <MAC_ADDRESS>"
            exit 1
        fi
        validate_mac "$2"
        msg_info "Removing $2..."
        guest_exec "bluetoothctl remove $2"
        ;;
    check-hw)
        . "${BTBOX_SRC_DIR}/check_hw.sh"
        check_hw
        ;;
    *)
        usage
        ;;
esac