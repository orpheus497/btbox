#!/bin/sh
##Script function and purpose: Main entry point for the btbox utility. Handles CLI argument parsing and dispatching to the VMM runner.
#
# btbox - Bluetooth Audio Sandbox for FreeBSD
#

set -e

# Resolve the directory where this script lives
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

# Load Common Library
# When installed, libraries are in /usr/local/lib/btbox/
# When running from source, they are in the same directory as this script (src/)
if [ -f "${SCRIPT_DIR}/common.sh" ]; then
    . "${SCRIPT_DIR}/common.sh"
elif [ -f "${SCRIPT_DIR}/../lib/btbox/common.sh" ]; then
    . "${SCRIPT_DIR}/../lib/btbox/common.sh"
else
    echo "Error: Cannot find common.sh library" >&2
    exit 1
fi

##Action purpose: Load configuration using common logic.
load_config

##Function purpose: Display usage information.
usage() {
    show_banner
    printf "Usage: btbox {start|stop|status|console}\n"
    exit 1
}

##Function purpose: Verify script is running as root.
check_root() {
    if [ "$(id -u)" -ne 0 ]; then
        ##Error purpose: Fail if not root.
        msg_err "btbox must be run as root."
        exit 1
    fi
}

##Action purpose: Parse command line arguments and execute sub-commands.
case "$1" in
    start)
        check_root
        show_banner
        msg_info "Starting btbox..."
        # Call the VMM runner
        sh "${BTBOX_SRC_DIR}/vmm/bhyve_runner.sh" start
        ;;
    stop)
        check_root
        msg_info "Stopping btbox..."
        sh "${BTBOX_SRC_DIR}/vmm/bhyve_runner.sh" stop
        ;;
    status)
        ##Condition purpose: Check if VM device exists.
        if [ -e "/dev/vmm/$VM_NAME" ]; then
            msg_status "btbox is running."
        else
            msg_status "btbox is not running."
        fi
        ;;
    console)
        check_root
        ##Condition purpose: Check if console device exists.
        if [ -e "$NMDM_B" ]; then
            msg_info "Connecting to console... (Press ~ then . to exit)"
            cu -l "$NMDM_B"
        else
            ##Error purpose: Fail if console not found.
            msg_err "Console not available."
        fi
        ;;
    *)
        usage
        ;;
esac